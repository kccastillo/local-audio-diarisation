{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(python -c *)",
      "Bash(rm *)",
      "Bash(rm -f *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/scripts/log-skill-usage.py"
          }
        ]
      }
    ]
  }
}
